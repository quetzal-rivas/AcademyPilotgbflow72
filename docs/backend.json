
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Academy owner or student profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Prospective student captured via automation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "status": { "type": "string" },
        "source": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AutomationRule": {
      "title": "AutomationRule",
      "description": "Autonomous flow logic defined by admin.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "trigger": { "type": "string" },
        "status": { "type": "string" },
        "actions": { "type": "array", "items": { "type": "object" } }
      }
    },
    "LandingPage": {
      "title": "LandingPage",
      "description": "Customized branch landing page configuration.",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "userId": { "type": "string" },
        "branchName": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["slug", "userId", "branchName", "isPublic"]
    }
  },
  "auth": {
    "providers": ["password", "magic-link"]
  },
  "firestore": {
    "/user_profiles/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Root profile for the unit."
    },
    "/user_profiles/{userId}/leads/{leadId}": {
      "schema": { "$ref": "#/backend/entities/Lead" },
      "description": "Recruitment registry for the academy."
    },
    "/user_profiles/{userId}/automation_rules/{ruleId}": {
      "schema": { "$ref": "#/backend/entities/AutomationRule" },
      "description": "Autonomous mission protocols."
    },
    "/landing_pages/{slug}": {
      "schema": { "$ref": "#/backend/entities/LandingPage" },
      "description": "Public registry for branch landing pages."
    }
  }
}
