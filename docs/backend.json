
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Academy owner or student profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Prospective student captured via automation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "status": { "type": "string" },
        "source": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "LandingPage": {
      "title": "LandingPage",
      "description": "Customized branch landing page configuration.",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "userId": { "type": "string" },
        "branchName": { "type": "string" },
        "headline": { "type": "string" },
        "subheadline": { "type": "string" },
        "callToAction": { "type": "string" },
        "contactPhone": { "type": "string" },
        "contactEmail": { "type": "string" },
        "address": { "type": "string" },
        "heroImage": { "type": "string", "format": "uri" },
        "isPublished": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["slug", "userId", "branchName", "isPublished"]
    }
  },
  "auth": {
    "providers": ["password", "magic-link"]
  },
  "firestore": {
    "/user_profiles/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Root profile for the unit."
    },
    "/landing_pages/{slug}": {
      "schema": { "$ref": "#/backend/entities/LandingPage" },
      "description": "Public registry for branch landing pages."
    }
  }
}
