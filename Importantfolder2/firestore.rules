
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /landingPages/{landingPageId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Leads sub-collection
      match /leads/{leadId} {
        // Public can create leads (submit the form)
        allow create: if true;
        // Only the tenant (owner of landingPageId) can read the leads
        allow read, update, delete: if isSignedIn() && get(/databases/$(database)/documents/landingPages/$(landingPageId)).data.userId == request.auth.uid;
      }
    }
  }
}
